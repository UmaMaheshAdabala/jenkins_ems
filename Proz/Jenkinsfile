pipeline{
    agent any

    stages{
        stage('Checkout'){
            steps{
                checkout scm
            }
        }

        stage('Frontend-Install Dependencies'){
            agent{
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps{
                dir('Proz/Employee_Management/Client'){
                    sh '''
                        export HOME=$PWD
                        export npm_config_cache=$PWD/.npm

                        npm ci
                       
                    '''
                }
            }
        }

        stage('Frontend-Build'){
            agent{
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps{
                dir('Proz/Employee_Management/Client'){
                    sh 'npm run build'
                }
            }
        }

    
        
        stage('Backend-Install Dependencies'){
            agent{
                docker{
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps{
                dir('Proz/Employee_Management/Server'){
                    sh '''
                        export HOME=$PWD
                        export npm_config_cache=$PWD/.npm

                        npm install
                    '''
                }
            }
        }

        stage('SonarQube Analysis'){
            steps{
               script{
                    def scannerHome = tool 'SonarScanner'

                    withSonarQubeEnv('SonarQube') {
                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=Employee-Management-System \
                        -Dsonar.projectName="Employee Management System" \
                        -Dsonar.projectVersion=1.0 \
                        -Dsonar.sources=Employee_Management/Server,Employee_Management/Client \
                        -Dsonar.exclusions=**/node_modules/**,**/dist/** \
                        -Dsonar.sourceEncoding=UTF-8
                        """
                    }
               }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build-Frontend-Docker-File'){
            steps{
                dir('Proz/Employee_Management/Client'){
                    sh 'docker build -t frontend-image:latest .'
                }
            }
        }

        stage('Build-Backend-DockerFile'){
            steps{
                dir('Proz/Employee_Management/Server'){
                    sh 'docker build -t backend-image:latest .'
                }
            }
        }
        
     }
}