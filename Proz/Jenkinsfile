pipeline{
    agent any

    stages{
        stage('Checkout'){
            steps{
                checkout scm
            }
        }

        stage('Frontend-Install Dependencies'){
            agent{
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps{
                dir('Proz/Employee_Management/Client'){
                    sh 'npm install'
                }
            }
        }

        stage('Frontend-Build'){
            agent{
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps{
                dir('Proz/Employee_Management/Client'){
                    sh 'npm run build'
                }
            }
        }

        stage('Frontend_lint'){
            agent{
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps{
                dir('Proz/Employee_Management/Client'){
                    sh 'npm run lint'
                }
            }
        }
        
        stage('Backend-Install Dependencies'){
            agent{
                docker{
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps{
                dir('Proz/Employee_Management/Server'){
                    sh 'npm install'
                }
            }
        }
        
     }
}