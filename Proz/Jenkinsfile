pipeline{
    agent any

    stages{
        stage('Checkout'){
            steps{
                checkout scm
            }
        }

        stage('SonarQube Analysis'){
            steps{
               script{
                    def scannerHome = tool 'SonarScanner'

                    withSonarQubeEnv('SonarQube') {
                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=Employee-Management-System \
                        -Dsonar.projectName="Employee Management System" \
                        -Dsonar.projectVersion=1.0 \
                        -Dsonar.sources=Proz/Employee_Management/Server,Proz/Employee_Management/Client/src \
                        -Dsonar.exclusions=**/node_modules/**,**/dist/** \
                        -Dsonar.sourceEncoding=UTF-8
                        """
                    }
               }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build-Frontend-Docker-File'){
            steps{
                dir('Proz/Employee_Management/Client') {

                    withCredentials([
                        string(credentialsId: 'VITE_BACKEND_URL',
                            variable: 'BACKEND_URL')
                    ]) {

                        sh """
                        docker build \
                        --build-arg VITE_BACKEND_URL=$BACKEND_URL \
                        -t frontend:${BUILD_NUMBER} .
                        """
                    }
                }
            }
        }

        stage('Build-Backend-DockerFile'){
            steps{
                dir('Proz/Employee_Management/Server'){
                    sh 'docker build -t backend:${BUILD_NUMBER} .'
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh '''
                mkdir -p trivy-reports

                echo "=============================="
                echo "Scanning Backend Image"
                echo "=============================="

                trivy image \
                --severity HIGH,CRITICAL \
                --ignore-unfixed \
                --format table \
                --output trivy-reports/backend-report.txt \
                --exit-code 1 \
                backend:${BUILD_NUMBER}

                echo "=============================="
                echo "Scanning Frontend Image"
                echo "=============================="

                trivy image \
                --severity HIGH,CRITICAL \
                --ignore-unfixed \
                --format table \
                --output trivy-reports/frontend-report.txt \
                --exit-code 1 \
                frontend:${BUILD_NUMBER}
                '''
            }
        }
        
     }
     post {
        always {
            archiveArtifacts artifacts: 'trivy-reports/*.txt', fingerprint: true
        }
    }
}